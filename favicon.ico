<script>
var currentLang = 'en';
function setLang(l){
  currentLang = l;
  document.body.classList.toggle('lang-zh', l === 'zh');
  document.body.classList.toggle('lang-es', l === 'es');
  document.querySelectorAll('.lang-toggle button').forEach(function(b){
    b.classList.toggle('active', b.dataset.lang === l);
  });
}
        // Apple-style nav: hover shows/hides on desktop; tap-to-toggle +
        // click-outside-to-close on touch; auto-detected via matchMedia.
        (function () {
            var supportsHover = !!(window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches);

            function closeAllMenus() {
                document.querySelectorAll('.an-item.open').forEach(function (item) {
                    item.classList.remove('open');
                    var trig = item.querySelector('.an-link[aria-haspopup]');
                    if (trig) trig.setAttribute('aria-expanded', 'false');
                });
            }

            document.querySelectorAll('.an-item').forEach(function (item) {
                var trigger = item.querySelector('.an-link[aria-haspopup]');
                if (!trigger) return; // items with no submenu need no toggle logic
                trigger.addEventListener('click', function (e) {
                    if (supportsHover) return; // desktop: hover alone controls visibility
                    e.preventDefault();
                    var willOpen = !item.classList.contains('open');
                    closeAllMenus();
                    if (willOpen) {
                        item.classList.add('open');
                        trigger.setAttribute('aria-expanded', 'true');
                    }
                });
            });

            document.addEventListener('click', function (e) {
                if (!e.target.closest('.an-item')) closeAllMenus();
            });

            var toggle = document.getElementById('anMobileToggle');
            var wrap = document.querySelector('.an-wrap');
            if (toggle && wrap) {
                toggle.addEventListener('click', function () {
                    var open = wrap.classList.toggle('an-open');
                    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                    if (!open) closeAllMenus();
                });
            }
            // Choosing an actual destination closes the submenu and the mobile panel
            document.querySelectorAll('.an-items a, .an-items button:not([aria-haspopup])').forEach(function (el) {
                el.addEventListener('click', function () {
                    closeAllMenus();
                    if (wrap) wrap.classList.remove('an-open');
                    if (toggle) toggle.setAttribute('aria-expanded', 'false');
                });
            });
        })();

</script>
<script>
function applyFilter(cat){
  document.querySelectorAll('.chip').forEach(function(c){ c.classList.toggle('active', c.dataset.cat === cat); });
  var any = false;
  document.querySelectorAll('.card').forEach(function(card){
    var show = (cat === 'all' || card.dataset.cat === cat);
    card.style.display = show ? '' : 'none';
    if (show) any = true;
  });
  document.getElementById('emptyMsg').style.display = any ? 'none' : 'block';
}
document.querySelectorAll('.chip').forEach(function(chip){
  chip.addEventListener('click', function(){ applyFilter(chip.dataset.cat); });
});
(function(){
  var params = new URLSearchParams(location.search);
  var cat = params.get('cat');
  if (cat && document.querySelector('.chip[data-cat="' + cat + '"]')) applyFilter(cat);
})();
</script>
</body>
</html>