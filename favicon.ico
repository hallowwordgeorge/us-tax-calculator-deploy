<style>
:root{
  --primary:#1d4ed8;--primary-light:#3b82f6;--primary-dark:#12275e;
  --success:#16a34a;--warning:#f59e0b;--danger:#dc2626;
  --bg:#f3f5fa;--card-bg:#ffffff;--text:#0f172a;--text-secondary:#64748b;--border:#e3e8f2;
  --shadow:0 1px 2px rgba(15,23,42,.05),0 10px 30px rgba(15,23,42,.06);
  --shadow-lg:0 4px 12px rgba(15,23,42,.06),0 24px 60px rgba(15,23,42,.12);
  --radius:18px;--radius-sm:12px;
}

.tab-btn{flex:0 0 auto;min-width:max-content;padding:12px 20px;border:none;background:transparent;color:var(--text-secondary);font-size:.95rem;font-weight:600;border-radius:10px;cursor:pointer;transition:all .22s cubic-bezier(.4,0,.2,1);white-space:nowrap;box-sizing:border-box;}
.tab-btn:hover{color:var(--primary);}
.site-nav{display:flex;gap:6px;overflow-x:auto;margin-bottom:14px;padding:5px;background:#e9edf6;border-radius:14px;flex-wrap:nowrap;-webkit-overflow-scrolling:touch;}
.sn-link{flex:none;padding:7px 14px;border-radius:10px;background:transparent;border:none;color:var(--text-secondary);text-decoration:none;font-size:.85rem;font-weight:600;transition:all .22s cubic-bezier(.4,0,.2,1);}
.sn-link:hover{color:var(--primary);}
.sn-link[aria-current="page"]{background:#ffffff;color:var(--primary);box-shadow:0 2px 8px rgba(15,23,42,.10);}
.mode-toggle,.lang-toggle{display:flex;gap:4px;background:#e9edf6;padding:4px;border-radius:12px;}
.mode-toggle button,.lang-toggle button{padding:8px 16px;border:none;background:transparent;border-radius:8px;font-size:.9rem;font-weight:600;cursor:pointer;transition:all .2s;color:var(--text-secondary);}
.mode-toggle button.active,.lang-toggle button.active{background:#ffffff;color:var(--primary);box-shadow:0 2px 8px rgba(15,23,42,.10);}

        /* ===== Apple-style flat nav ===== */
        .apple-nav{background:#ffffff;border-bottom:1px solid var(--border);position:relative;z-index:100;}
        .an-wrap{max-width:1200px;margin:0 auto;padding:0 24px;height:54px;display:flex;align-items:center;gap:4px;position:relative;}
        .an-logo{display:flex;align-items:center;gap:8px;text-decoration:none;flex:none;margin-right:18px;}
        .an-logo img{border-radius:7px;}
        .an-wordmark{font-size:.92rem;font-weight:800;color:var(--primary-dark);letter-spacing:-0.01em;white-space:nowrap;}
        .an-items{display:flex;align-items:center;gap:2px;list-style:none;flex:1;min-width:0;}
        .an-item{position:relative;}
        .an-lang-item{margin-left:auto;}
        .an-link,.an-details summary{
            display:inline-flex;align-items:center;gap:5px;background:transparent;border:none;
            color:var(--text);font-size:.86rem;font-weight:500;padding:8px 12px;border-radius:8px;
            cursor:pointer;white-space:nowrap;list-style:none;
        }
        .an-link{text-decoration:none;}
        .an-item:hover>.an-link,.an-item.open>.an-link{color:var(--primary);background:#f5f7fb;}
        .an-menu{display:none;flex-direction:column;gap:1px;min-width:200px;position:absolute;top:100%;left:0;margin-top:6px;background:#fff;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow-lg);padding:8px;z-index:110;}
        .an-item.open>.an-menu,.an-item:focus-within>.an-menu{display:flex;}
        @media (hover:hover) and (pointer:fine){
            .an-item:hover>.an-menu{display:flex;}
        }
        .an-menu a,.an-menu button.dropdown-tab-btn{
            display:block;width:100%;text-align:left;padding:9px 12px;border-radius:8px;
            font-size:.86rem;color:var(--text);text-decoration:none;background:transparent;border:none;
        }
        .an-menu a:hover,.an-menu button.dropdown-tab-btn:hover{background:#f5f7fb;color:var(--primary);}
        .an-menu a[aria-current="page"]{color:var(--primary);font-weight:700;}
        .an-menu .an-menu-all{color:var(--primary);font-weight:700;border-top:1px solid var(--border);margin-top:4px;padding-top:10px;}
        .an-lang{background:#f2f4f8;padding:3px;border-radius:8px;gap:2px;}
        .an-lang button{padding:6px 10px;font-size:.76rem;}
        .an-mobile-toggle{display:none;margin-left:auto;background:none;border:none;font-size:1.3rem;color:var(--text);cursor:pointer;padding:6px 8px;}
        .an-menu.site-nav{margin-bottom:0;overflow:visible;}

        @media(max-width:860px){
            .an-wordmark{display:none;}
            .an-mobile-toggle{display:block;}
            .an-items{
                display:none;position:absolute;top:100%;left:0;right:0;
                flex-direction:column;align-items:stretch;background:#fff;
                border-top:1px solid var(--border);box-shadow:var(--shadow-lg);
                padding:10px;gap:0;max-height:calc(100vh - 54px);overflow-y:auto;
            }
            .an-wrap.an-open .an-items{display:flex;}
            .an-lang-item{margin-left:0;order:99;padding-top:8px;border-top:1px solid var(--border);margin-top:6px;}
            .an-link{width:100%;padding:12px 10px;}
            .an-item.open>.an-menu{
                position:static;display:flex;box-shadow:none;border:none;padding:0 0 4px 20px;margin-top:0;
            }
                }


*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.65;}
a{color:var(--primary);}

/* i18n */
.i18n-zh,.i18n-es{display:none;}
body.lang-zh .i18n-zh{display:inline;}
body.lang-zh .i18n-en,body.lang-zh .i18n-es{display:none;}
body.lang-es .i18n-es{display:inline;}
body.lang-es .i18n-en,body.lang-es .i18n-zh{display:none;}
.i18n-zh.block,.i18n-en.block,.i18n-es.block{display:none;}
body.lang-zh .i18n-zh.block{display:block;}
body.lang-es .i18n-es.block{display:block;}
body:not(.lang-zh):not(.lang-es) .i18n-en.block{display:block;}
body:not(.lang-zh):not(.lang-es) .i18n-en{display:inline;}

/* Fill the screen below the nav bar: page sections run full-bleed width,
   only the actual reading text is kept to a comfortable column. */
.page-wide{max-width:1200px;margin:0 auto;padding:0 24px;}
.prose{max-width:760px;margin:0 auto;padding:0 24px;}

.page-intro{padding:30px 0 6px;}
.page-intro h1{font-size:1.6rem;font-weight:800;color:var(--primary-dark);margin-bottom:8px;}
.page-intro p{color:var(--text-secondary);font-size:.97rem;max-width:680px;}

.chips{display:flex;flex-wrap:wrap;gap:8px;margin:20px 0 26px;}
.chip{padding:6px 14px;border:1px solid var(--border);background:#fff;border-radius:999px;font-size:.85rem;color:var(--text-secondary);cursor:pointer;text-decoration:none;}
.chip:hover{border-color:var(--primary-light);color:var(--primary);}
.chip.active{background:var(--primary);border-color:var(--primary);color:#fff !important;}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;margin-bottom:48px;}
.card{display:flex;flex-direction:column;gap:9px;padding:22px;border:1px solid var(--border);border-radius:16px;background:var(--card-bg);text-decoration:none;color:inherit;transition:transform .15s,box-shadow .15s,border-color .15s;}
.card:hover{transform:translateY(-3px);box-shadow:0 10px 26px rgba(16,42,90,.10);border-color:var(--primary-light);}
.badge{align-self:flex-start;font-size:.72rem;font-weight:700;color:var(--primary);background:rgba(26,95,180,.10);padding:3px 11px;border-radius:999px;}
.card h3{font-size:1.06rem;font-weight:700;line-height:1.35;color:var(--text);}
.card p{font-size:.89rem;color:var(--text-secondary);line-height:1.55;flex:1;}
.meta{font-size:.76rem;color:#93a0b3;}

.back-link{display:inline-block;margin:26px 0 8px;font-size:.87rem;font-weight:700;text-decoration:none;}
.article-head{padding:10px 0 6px;}
.article-head .meta-row{display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap;}
.article-head h1{font-size:1.9rem;line-height:1.28;font-weight:800;color:var(--primary-dark);margin:6px 0 28px;letter-spacing:-.01em;}
.article-body{font-size:1.06rem;line-height:1.85;padding-bottom:14px;}
.article-body h5{font-size:1.15rem;font-weight:700;margin:28px 0 10px;color:var(--primary-dark);}
.article-body p{margin:0 0 16px;}
.article-body ul{margin:0 0 16px;padding-left:24px;}
.article-body li{margin-bottom:7px;}
.article-body table{width:100%;border-collapse:collapse;margin:0 0 18px;font-size:.93rem;}
.article-body th,.article-body td{border:1px solid var(--border);padding:9px 11px;text-align:left;}
.article-body th{background:#eef1f8;}
.article-body .tip-box,.article-body .warning-box,.article-body .danger-box{padding:13px 15px;border-radius:12px;margin:0 0 18px;font-size:.94rem;}
.article-body .tip-box{background:#eef6ff;border:1px solid #cfe3ff;}
.article-body .warning-box{background:#fff8ec;border:1px solid #ffe2ad;}
.article-body .danger-box{background:#fef1f1;border:1px solid #ffc9c9;}
.more-box{margin:34px 0 50px;padding:22px;border:1px solid var(--border);border-radius:16px;background:var(--card-bg);}
.more-box h4{font-size:.85rem;margin-bottom:10px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.05em;font-weight:700;}
.more-box a{display:block;padding:9px 0;font-size:.95rem;font-weight:600;text-decoration:none;border-bottom:1px solid var(--border);}
.more-box a:last-child{border-bottom:none;}

.empty{padding:44px 0;text-align:center;color:var(--text-secondary);}

.site-footer{border-top:1px solid var(--border);margin-top:24px;padding:26px 0 44px;color:var(--text-secondary);font-size:.83rem;}
.site-footer a{color:var(--text-secondary);text-decoration:none;}
.site-footer a:hover{color:var(--primary);}
.site-footer .flinks{margin-bottom:10px;}
.site-footer .flinks a{color:var(--primary);font-weight:600;}

@media(max-width:600px){
  .article-head h1{font-size:1.5rem;}
  .page-intro h1{font-size:1.35rem;}
}

</style>
</head>
